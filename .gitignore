# ── Secrets & Config ──────────────────────────────────────────────────────────
config.yaml
config.yaml.bak*
config.yaml.backup.*
config.yaml.no_sonnet
config.bailian.yaml
**/feishu_ops/feishu.json

# ── Compiled Binaries ─────────────────────────────────────────────────────────
/server

# ── Runtime State ─────────────────────────────────────────────────────────────
bot.db
bot.db.*
nohup.out
server.pid
*.log
*.log.*
*.log.wf

# ── Python test cache ─────────────────────────────────────────────────────────
.pytest_cache/

# ── Local Claude Settings (tool permissions, not for sharing) ─────────────────
**/.claude/settings.local.json

# ── Python Bytecode (feishu_ops/scripts) ──────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── feishu_ops local doc cache (runtime) ──────────────────────────────────────
**/feishu_ops/index/

# ── Workspace Runtime Data ────────────────────────────────────────────────────
# Session directories contain user conversation data
workspaces/*/sessions/
# Memory files contain personal/sensitive user data
workspaces/*/memory/
# Task YAML files are runtime state managed by the bot
workspaces/*/tasks/
# Temp attachment downloads
workspaces/*/tmp/
# flock lock file
workspaces/*/.memory.lock

# ── Template exceptions (these are source files, not runtime data) ─────────────
!workspaces/_template/memory/
!workspaces/_template/.claude/
!workspaces/_companion/memory/
!workspaces/_companion/tasks/
!workspaces/_companion/.claude/settings.local.json
